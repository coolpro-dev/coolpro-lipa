# Site URL (Vercel sets VERCEL_URL automatically in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (NEVER expose SERVICE_ROLE_KEY to client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare Turnstile (https://dash.cloudflare.com)
# In production: both required for captcha protection
# In development: set TURNSTILE_BYPASS_DEV=true to skip verification
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_BYPASS_DEV=true

# Upstash Redis for distributed rate limiting (optional, falls back to in-memory)
# Get free tier at https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: Resend email notifications
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=

# Optional: PostHog analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# =============================================================================
# SECURITY NOTES
# =============================================================================
# 1. SUPABASE_SERVICE_ROLE_KEY must NEVER be prefixed with NEXT_PUBLIC_
#    It bypasses Row Level Security and should only be used server-side
#
# 2. In production:
#    - Remove TURNSTILE_BYPASS_DEV or set to false
#    - Configure Upstash Redis for distributed rate limiting
#    - Ensure all Turnstile keys are configured
#
# 3. Rate limits (configurable in lib/security/rate-limiter.ts):
#    - 3 requests per minute per IP
#    - 10 requests per hour per IP
#    - 30 requests per day per IP
#    - 15 minute soft-ban after 5 consecutive failures
